[sqlfluff]
dialect = snowflake
templater = jinja
exclude_rules = L009,L031
max_line_length = 120

[sqlfluff:rules]
indent_unit = space
indent_width = 4

[sqlfluff:rules:L010]  # Keywords capitalization
capitalisation_policy = upper

[sqlfluff:rules:L014]  # Unquoted identifiers
extended_capitalisation_policy = upper

[sqlfluff:rules:L016]  # Line length
max_line_length = 120

[sqlfluff:rules:L029]  # Keyword spacing
unquoted_identifiers_policy = upper

[sqlfluff:rules:L034]  # Select wildcards
allow_select_wildcard = False

[sqlfluff:rules:L043]  # Consistent null ordering
null_ordering = nulls_last